{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/event/create", "destination": "/event/create.html" },
    { "source": "/event/:id", "destination": "/event/[id].html" },
    { "source": "/booking/:slug", "destination": "/booking/[slug].html" }
  ]
}
